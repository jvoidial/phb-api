#!/bin/bash

echo "🛡 PHB WATCHDOG ONLINE"

cd /data/data/com.termux/files/home/phb-api

while true; do

    if ! pgrep -f uvicorn > /dev/null; then
        echo "[WATCHDOG] kernel down → restarting..."
        nohup uvicorn main:app --host 0.0.0.0 --port 8000 > phb.log 2>&1 &
    fi

    sleep 5
done
